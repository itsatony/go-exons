{
  "comments": {
    "blockComment": ["{~exons.comment~}", "{~/exons.comment~}"]
  },
  "brackets": [
    ["{~", "~}"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{~", "close": "~}" },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" }
  ],
  "surroundingPairs": [
    ["{~", "~}"],
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "\\{~(?!/)(?!.*\\/~\\})",
      "end": "\\{~/.*~\\}"
    }
  }
}
